# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.

# Notion integration internal token (starts with `secret_` or `ntn_`)
NOTION_TOKEN=

# Notion database ID for the dayblog-journal DB (32-char hex, dashes optional)
NOTION_DATABASE_ID=

# Absolute path to the Hugo site repo root (content/posts/ lives under this)
HUGO_SITE_ROOT=D:\vscodeprojects\blog
